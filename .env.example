# Copy this to .env (already gitignored) and fill in your own keys.
# Both keys can also be configured through the Settings panel at runtime —
# env vars take precedence.

# Groq API key — sign up at https://console.groq.com
# Has a rate-limited free tier (~30 req/min on most models) and a pay-as-you-go
# paid tier (~$0.05-$0.80 per 1M tokens depending on model). Either works.
GROQ_API_KEY=gsk_your_key_here

# Bankr API key — generate at https://bankr.bot/api
BANKR_API_KEY=bk_your_key_here

# Optional — override the HTTP port (default 3847)
# PORT=3847
